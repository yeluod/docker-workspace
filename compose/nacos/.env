NACOS_IMAGE="nacos/nacos-server:latest"
NACOS_CONTAINER_NAME="nacos-server"

MODE="standalone"
PREFER_HOST_MODE="ip"

NACOS_SERVER_PORT="8848"
NACOS_CONSOLE_PORT="8080"
NACOS_GRPC_PORT="9848"

SPRING_DATASOURCE_PLATFORM="mysql"
MYSQL_DATABASE_NUM="1"
MYSQL_SERVICE_HOST="192.168.1.120"
MYSQL_SERVICE_PORT="3306"
MYSQL_SERVICE_DB_NAME="nacos_config"
MYSQL_SERVICE_USER="root"
MYSQL_SERVICE_PASSWORD="123456"
MYSQL_ROOT_PASSWORD="123456"
MYSQL_SERVICE_DB_PARAM="characterEncoding=utf8&connectTimeout=1000&socketTimeout=3000&autoReconnect=true&useSSL=false&serverTimezone=Asia/Shanghai"

JVM_XMS="2048m"
JVM_XMX="2048m"
JVM_XMN="256m"
JVM_MS="128m"
JVM_MMS="320m"

NACOS_AUTH_SYSTEM_TYPE="nacos"
NACOS_AUTH_ENABLE="true"
NACOS_AUTH_ADMIN_ENABLE="true"
NACOS_AUTH_CONSOLE_ENABLE="true"
NACOS_AUTH_TOKEN_EXPIRE_SECONDS="18000"
NACOS_AUTH_TOKEN="VGhpc0lzTXlDdXN0b21TZWNyZXRLZXkwMTIzNDU2Nzg="
NACOS_AUTH_CACHE_ENABLE="false"
NACOS_AUTH_IDENTITY_KEY="serverIdentity"
NACOS_AUTH_IDENTITY_VALUE="security"

HOST_WORK_DIR="/Users/wang/workspace/docker_work/nacos"
